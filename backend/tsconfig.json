{
  "compilerOptions": {
    // File Layout - Enable source and output directories
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings for Node.js
    "module": "ES2020",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],

    // Module Resolution - using 'bundler' to avoid requiring .js extensions
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,

    // Output Options
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,

    // TypeScript Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Module Syntax
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "esm": true,
    "experimentalEsm": true
  }
}
